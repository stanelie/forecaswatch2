{
  "name": "forecaswatch2",
  "author": "Matt Rossman",
  "version": "1.34.0",
  "buildProfile": "{{buildProfile}}",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "suncalc": "^1.9.0"
  },
  "pebble": {
    "displayName": "{{displayName}}",
    "uuid": "{{uuid}}",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "diorite",
      "emery",
      "flint"
    ],
    "watchapp": {
      "watchface": true
    },
    "resources": {
      "media": [
        {
          "menuIcon": true,
          "type": "png",
          "name": "IMAGE_MENU_ICON",
          "file": "icon.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_MUTE",
          "file": "img/mute.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BT_DISCONNECT",
          "file": "img/bt-disconnect.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BT_CONNECT",
          "file": "img/bt.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BATTERY_CHARGING",
          "file": "img/battery-charging.png",
          "memoryFormat": "1BitPalette"
        },
        { "type": "png", "name": "IMAGE_WEATHER_CLEAR_DAY",    "file": "img/weather/clear-day.png" },
        { "type": "png", "name": "IMAGE_WEATHER_CLEAR_NIGHT",  "file": "img/weather/clear-night.png" },
        { "type": "png", "name": "IMAGE_WEATHER_PARTLY_CLOUDY","file": "img/weather/partly-cloudy.png" },
        { "type": "png", "name": "IMAGE_WEATHER_CLOUDY",       "file": "img/weather/cloudy.png" },
        { "type": "png", "name": "IMAGE_WEATHER_FOG",          "file": "img/weather/fog.png" },
        { "type": "png", "name": "IMAGE_WEATHER_DRIZZLE",      "file": "img/weather/drizzle.png" },
        { "type": "png", "name": "IMAGE_WEATHER_RAIN",         "file": "img/weather/rain.png" },
        { "type": "png", "name": "IMAGE_WEATHER_SNOW",         "file": "img/weather/snow.png" },
        { "type": "png", "name": "IMAGE_WEATHER_THUNDER",      "file": "img/weather/thunder.png" },
        { "type": "png", "name": "IMAGE_WEATHER_NA",           "file": "img/weather/na.png" }
      ]
    },
    "capabilities": [
      "location",
      "configurable"
    ],
    "messageKeys": [
      "TEMP_TREND_INT16",
      "PRECIP_TREND_UINT8",
      "FORECAST_START",
      "NUM_ENTRIES",
      "CURRENT_TEMP",
      "CITY",
      "SUN_EVENTS",
      "WATCH_HAS_FORECAST_DATA",
      "CLAY_CELSIUS",
      "CLAY_TIME_LEAD_ZERO",
      "CLAY_AXIS_12H",
      "CLAY_START_MON",
      "CLAY_COLOR_TODAY",
      "CLAY_PREV_WEEK",
      "CLAY_TIME_FONT",
      "CLAY_SHOW_QT",
      "CLAY_SHOW_BT",
      "CLAY_SHOW_BT_DISCONNECT",
      "CLAY_VIBE",
      "CLAY_SHOW_AM_PM",
      "CLAY_COLOR_SATURDAY",
      "CLAY_COLOR_SUNDAY",
      "CLAY_COLOR_US_FEDERAL",
      "CLAY_COLOR_TIME",
      "CLAY_DAY_NIGHT_SHADING",
      "CLAY_SHOW_CALENDAR",
      "CLAY_BATTERY_CIRCULAR",
      "CONDITION_CODE"
    ]
  }
}
